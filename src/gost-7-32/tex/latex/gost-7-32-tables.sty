\ProvidesPackage{gost-7-32-tables}[2022/01/28 GOST 7.32-2017]

\RequirePackage{environ}
\RequirePackage{xltabular}

%
% Center-aligned column with automatic width
%
\newcolumntype{Y}{>{\centering\arraybackslash}X}

%
% Right-aligned column with automatic width
%
\newcolumntype{Z}{>{\raggedleft\arraybackslash}X}

%
% Table with designations
%
\NewEnviron{designations}{%
  \begin{xltabular}{\textwidth}{@{}
    >{\raggedright\arraybackslash\hsize=0.25\hsize}X
    >{\centering\arraybackslash\hsize=0.05\hsize}X
    >{\arraybackslash\hsize=0.70\hsize}X
  }
  \BODY
  \end{xltabular}
}

\newcommand{\designation}[2]{#1 &---& #2. \\}
